{
  "swaggerUi": "/docs",
  "swaggerJson": "/docs/swagger.json",
  "endpoints": [
    { "method": "POST", "path": "/api/auth/sign-up", "tag": "auth" },
    { "method": "POST", "path": "/api/auth/sign-in", "tag": "auth" },
    { "method": "POST", "path": "/api/auth/guest-session", "tag": "auth" },
